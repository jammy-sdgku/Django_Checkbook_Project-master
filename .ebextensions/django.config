option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: Django_Checkbook/Django_Checkbook/wsgi.py
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: Django_Checkbook.settings

files:
  "/var/app/staging/Procfile":
    mode: "000644"
    owner: webapp
    group: webapp
    content: |
      web: gunicorn --bind 127.0.0.1:8000 --workers 3 --threads 2 --pythonpath /var/app/current/Django_Checkbook Django_Checkbook.wsgi:application
